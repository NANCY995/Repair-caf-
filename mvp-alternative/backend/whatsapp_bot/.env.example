# === WhatsApp Cloud API ===
WHATSAPP_TOKEN="votre_token_acces_meta"
WHATSAPP_PHONE_NUMBER_ID="votre_phone_number_id"
WHATSAPP_VERIFY_TOKEN="votre_token_verification_webhook"
# App Secret Meta (dashboard de l'app Meta > Paramètres > Avancé) — REQUIRED en prod
# Sert à vérifier la signature X-Hub-Signature-256 du webhook (anti-spoofing)
WHATSAPP_APP_SECRET="votre_app_secret_meta"
WHATSAPP_API_VERSION="v22.0"

# === Google Sheets ===
GOOGLE_SHEETS_CREDENTIALS_PATH="credentials/google-sheets-creds.json"
GOOGLE_SHEETS_SPREADSHEET_ID="votre_spreadsheet_id"

# === IA (OpenAI / autre LLM) ===
OPENAI_API_KEY="votre_cle_api_openai"
OPENAI_MODEL="gpt-4o-mini"

# === Application ===
APP_ENV="development"  # development | production
# IMPORTANT : générez des valeurs aléatoires (ex: python -c "import secrets;print(secrets.token_hex(32))")
APP_SECRET_KEY="changez_moi_en_production"
# Token d'accès aux endpoints admin (/dashboard, /api/sessions, /api/conversations, /api/test/send, ...)
# Saisissez-le dans la boîte de dialogue du navigateur (Basic Auth) ou en en-tête X-Admin-Token
ADMIN_API_TOKEN="changez_moi_en_production"
# Numéro WhatsApp du réparateur/équipe BUTUS pour recevoir les alertes de réservation pièces
BUTUS_NOTIFICATION_PHONE="+22890000000"
